# LLM —— OpenAI-compatible API endpoint
LLM_BASE_URL=https://api.minimaxi.com/v1
LLM_API_KEY=<your-minimax-api-key>
LLM_MODEL=MiniMax-M2.7
LLM_LIGHT_MODEL=MiniMax-M2.7

# Legacy (no longer used)
DEEPSEEK_API_KEY=

# Neo4j Structured DB
NEO4J_STRUCTURED_URI=bolt://localhost:7687
NEO4J_STRUCTURED_USER=neo4j
NEO4J_STRUCTURED_PASSWORD=<change-me>
NEO4J_STRUCTURED_DATABASE=neo4j

# Neo4j Unstructured DB (single-instance setup, same Neo4j)
NEO4J_UNSTRUCTURED_URI=bolt://localhost:7687
NEO4J_UNSTRUCTURED_USER=neo4j
NEO4J_UNSTRUCTURED_PASSWORD=<change-me>
NEO4J_UNSTRUCTURED_DATABASE=neo4j

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=1800

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=<change-me>
MYSQL_DATABASE=ai_customer_service

# JWT —— generate with `openssl rand -hex 32`
JWT_SECRET_KEY=<generate-with-openssl-rand-hex-32>
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# Server
HOST=0.0.0.0
PORT=8001
DEBUG=true
